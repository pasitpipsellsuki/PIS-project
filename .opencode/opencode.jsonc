{
  "$schema": "https://opencode.ai/config.json",
  // Theme configuration
  "theme": "opencode",
  "model": "anthropic/claude-sonnet-4-5",
  "autoupdate": true,
  "agent": {
    "priya": {
      "description": "Product Owner — intake, stories, backlog",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "{file:./skills/skills-po.md}"
    },
    "dexter": {
      "description": "Software Developer — implement, test, PR",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "{file:./skills/skills-dev.md}"
    },
    "quinn": {
      "description": "QA Engineer — test plans, bug reports, sign-off",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "{file:./skills/skills-qa.md}"
    },
    "devon": {
      "description": "DevOps Engineer — deploy, monitor, rollback",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "{file:./skills/skills-devops.md}"
    }
  }
}